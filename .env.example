# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Drive
# Path to your service account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
# The ID of the root folder in Drive where all client proposal folders live
# e.g. https://drive.google.com/drive/folders/THIS_PART
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_root_folder_id_here

# App
# Secret key for session management (generate a random string)
APP_SECRET_KEY=change_this_to_a_random_secret
